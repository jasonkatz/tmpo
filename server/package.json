{
    "name": "tmpo-server",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "dev:daemon": "bun --watch src/daemon.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "build:binary": "bun build src/daemon.ts --compile --outfile tmpod",
        "start": "bun dist/index.js",
        "start:daemon": "bun src/daemon.ts",
        "openapi:gen": "bunx openapi-typescript schema.yaml -o src/types/api.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "bun test",
        "test:watch": "bun test --watch"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "express-openapi-validator": "^5.3.8",
        "express-rate-limit": "^7.5.0",
        "smol-toml": "^1.3.1",
        "uuid": "^11.0.5",
        "winston": "^3.17.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "openapi-typescript": "^7.4.4",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.19.1"
    }
}
